
  overflow: visible;
  position: relative;
  z-index: 2;
  overflow: visible;
}

.tma-portal-head__actions .tma-dash__head-dropdown-wrap,
.tma-portal-toolbar__group .tma-dash__head-dropdown-wrap,
.tma-portal-empty__cta .tma-dash__head-dropdown-wrap {
  display: inline-flex;
}

/* toolbar actions - compact size (legacy no-data CTA buttons) */
.tma-portal-head__actions .tma-no-data__btn {
  min-height: 28px;
  min-width: 0;
  padding: var(--space-4) var(--space-12);
  border-radius: var(--radius-12);
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  align-items: flex-end;

.tma-portal-toolbar__group--search {
  flex: 0 0 auto;
  align-items: flex-end;
}

.tma-portal-toolbar__group--search .tma-dash__toolbar-search {
  width: 240px;
  flex: 0 0 auto;
}

.tma-portal-toolbar__group--filters {
  align-items: flex-end;
  flex-shrink: 0;
}

.tma-portal-toolbar .tma-portal-field {
  gap: var(--space-4);
  min-width: 0;
}

.tma-portal-toolbar .tma-portal-field__label {
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  font-weight: 400;
  color: var(--color-text-secondary);
}

.tma-portal-toolbar .tma-portal-field .tma-portal-select {
  max-width: none;
  min-height: 28px;
  padding: 2px var(--space-8);
  border-radius: var(--radius-16);
  border-width: 0.5px;
  border-color: var(--color-border-medium);
  background: var(--color-bg-input);
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
}
/* native bulk checkbox - empty box when unchecked (matches Users/Files tables) */
.tma-portal-table .tma-dash__check {
  width: 16px;
  height: 16px;
  margin: 0;
  border-radius: var(--radius-4);
  accent-color: var(--color-black);
  cursor: pointer;
  vertical-align: middle;
}

.tma-portal-table[data-has-selection] .tma-dash__check {
  accent-color: var(--color-accent);
}

.tma-portal-table th.tma-portal-cell--tight,
.tma-portal-table td.tma-portal-cell--tight {
  text-align: center;
}

.tma-portal-table tbody tr.tma-portal-table__row--selected td {
  background: var(--color-accent-bg);
}

.tma-portal-table tbody tr.tma-portal-table__row--selected:hover td {
  background: var(--color-accent-bg-hover);
}

/* selection toolbar - icon-only; label expands on hover to stay one line */
.tma-portal-selection-bar {
  display: flex;
  align-items: center;
  min-height: 32px;
  margin-bottom: var(--space-4);
  min-width: 0;
}

.tma-portal-selection-bar__actions {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: nowrap;
  min-width: 0;
  max-width: 100%;
  overflow-x: auto;
  scrollbar-width: none;
}

.tma-portal-selection-bar__actions::-webkit-scrollbar { display: none; }

.tma-portal-selection-bar__action {
  display: inline-flex;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
  padding: var(--space-4);
  border: 0;
  border-radius: var(--radius-8);
  background: transparent;
  font-family: inherit;
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-accent);
  cursor: pointer;
  white-space: nowrap;
  transition: gap 0.15s ease, padding 0.15s ease, background 0.15s ease;
}

.tma-portal-selection-bar__label {
  display: inline-block;
  max-width: 0;
  opacity: 0;
  overflow: hidden;
  white-space: nowrap;
  transition: max-width 0.15s ease, opacity 0.15s ease;
}

.tma-portal-selection-bar__action:hover,
.tma-portal-selection-bar__action:focus-visible {
  gap: var(--space-4);
  padding: var(--space-4) var(--space-8);
  background: var(--color-accent-bg);
}

.tma-portal-selection-bar__action:hover .tma-portal-selection-bar__label,
.tma-portal-selection-bar__action:focus-visible .tma-portal-selection-bar__label {
  max-width: 12rem;
  opacity: 1;
}

.tma-portal-selection-bar__action img {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  filter: brightness(0) saturate(100%) invert(32%) sepia(89%) saturate(747%) hue-rotate(169deg) brightness(92%) contrast(95%);
}

.tma-portal-selection-bar__divider {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  opacity: 0.35;
}

/* compact action menu (selection bar › More, etc.) */
.tma-portal-menu-pop {
  position: fixed;
  z-index: 260;
  display: flex;
  flex-direction: column;
  width: max-content;
  max-width: min(240px, calc(100vw - 16px));
  padding: var(--space-12);
  border-radius: var(--radius-16);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  font-family: var(--font-family);
  font-feature-settings: var(--font-features);
}

.tma-portal-menu-pop__item {
  display: block;
  width: 100%;
  margin: 0;
  padding: var(--space-8);
  border: 0;
  border-radius: var(--radius-12);
  background: transparent;
  font-family: inherit;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  font-weight: 400;
  color: var(--color-text-primary);
  text-align: left;
  white-space: nowrap;
  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;
}

.tma-portal-menu-pop__item:hover { background: var(--color-hover); }

.tma-portal-menu-pop__item:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}
/* file row right-click context menu */
.tma-portal-context-menu {
  position: fixed;
  z-index: 500;
  display: flex;
  flex-direction: column;
  width: max-content;
  padding: var(--space-4);
  border-radius: var(--radius-12);
  background: var(--color-white);
  border: 0.5px solid var(--color-border-soft);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
  box-sizing: border-box;
  font-family: var(--font-family);
  font-feature-settings: var(--font-features);
}

.tma-portal-context-menu__item {
  display: block;
  width: 100%;
  margin: 0;
  padding: var(--space-8) var(--space-12);
  border: 0;
  border-radius: var(--radius-8);
  background: transparent;
  font-family: inherit;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  font-weight: 400;
  color: var(--color-text-primary);
  text-align: left;
  white-space: nowrap;
  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;
}

.tma-portal-context-menu__item:hover { background: var(--color-hover); }

/* favorite star - always visible; muted outline, full opacity when starred (column after checkbox) */
.tma-portal-checkbox input { width: 16px; height: 16px; accent-color: var(--color-accent); }

.tma-portal-checkbox--toolbar {
  align-self: flex-end;
}

/* ── signature requests ───────────────────────────── */
.tma-portal-head__title-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  min-width: 0;
}

.tma-portal-head__title-wrap .tma-portal-head__title {
  margin: 0;
}

.tma-portal-sig-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
}

.tma-portal-sig-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  align-items: center;
  gap: var(--space-16);
  padding: var(--space-16) var(--space-20);
  border: 1px solid var(--color-border-soft);
  border-radius: var(--radius-16);
  background: var(--color-white);
  min-width: 0;
  cursor: pointer;
  transition: background 0.15s ease, border-color 0.15s ease;
}

.tma-portal-sig-card:hover {
  background: var(--color-hover);
}

.tma-portal-sig-card:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
}

.tma-portal-sig-card__actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.tma-portal-page--signatures .tma-portal-toolbar {
  margin-top: var(--space-4);
}

/* ── signature request wizard (fullscreen) ────────── */
/* Do NOT lock .tma-dash__main overflow - a stuck wizard class
   would permanently kill wheel/touch scrolling in the content area.
   The fixed overlay already covers the viewport. */
html.tma-dash--signatures-wizard,
html.tma-dash--signatures-wizard body {
  overflow: hidden;
  overscroll-behavior: none;
  touch-action: none;
}

.tma-dash--signatures-wizard .tma-dash__main-head,
.tma-dash--signatures-wizard .tma-dash__footer {
  display: none;
}

.tma-portal-sig-wizard {
  display: flex;
  flex-direction: column;
  position: fixed;
  inset: 0;
  z-index: 280;
  width: 100%;
  height: 100%;
  max-height: 100dvh;
  overscroll-behavior: contain;
  touch-action: auto;
  margin: 0;
  background: var(--color-white);
  border: 0;
  border-radius: 0;
  overflow: hidden;
}

.tma-portal-sig-wizard__head {
  flex-shrink: 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  align-items: center;
  gap: var(--space-16);
  padding: var(--space-16) var(--space-24);
  border-bottom: 1px solid var(--color-border-soft);
}

.tma-portal-sig-wizard__title {
  margin: 0;
  font-size: var(--text-size-18);
  line-height: var(--text-lh-18);
  font-weight: 600;
  color: var(--color-black);
}

.tma-portal-sig-wizard__steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  min-width: 0;
}

.tma-portal-sig-wizard__step {
  display: inline-flex;
  align-items: center;
  gap: var(--space-8);
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.tma-portal-sig-wizard__step.is-active {
  color: var(--color-accent);
}

.tma-portal-sig-wizard__step.is-done {
  color: var(--chart-green, #71dd8c);
}

.tma-portal-sig-wizard__step.is-done .tma-portal-sig-wizard__step-icon img {
  opacity: 1;
  filter: none;
}

.tma-portal-sig-wizard__step-line.is-done {
  border-top-color: var(--chart-green, #71dd8c);
}

.tma-portal-sig-wizard__step-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}

.tma-portal-sig-wizard__step-icon img {
  width: 18px;
  height: 18px;
  opacity: 0.55;
}

.tma-portal-sig-wizard__step.is-active .tma-portal-sig-wizard__step-icon img,
.tma-portal-sig-wizard__step.is-done .tma-portal-sig-wizard__step-icon img {
  opacity: 1;
}

.tma-portal-sig-wizard__step-label {
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
}

.tma-portal-sig-wizard__step-line {
  width: 28px;
  height: 0;
  border-top: 2px dotted var(--color-border-soft);
  flex-shrink: 0;
}

.tma-portal-sig-wizard__close {
  justify-self: end;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border: 0;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-portal-sig-wizard__close:hover {
  background: var(--color-hover);
}

.tma-portal-sig-wizard__close img {
  width: 18px;
  height: 18px;
  opacity: 0.7;
}

.tma-portal-sig-wizard__body {
  flex: 1 1 auto;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-28);
  padding: var(--space-28) var(--space-32);
  overflow-y: auto;
}

.tma-portal-sig-wizard__section {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  max-width: 920px;
}

.tma-portal-sig-wizard__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-16);
  flex-wrap: wrap;
}

.tma-portal-sig-wizard__section-title {
  margin: 0;
  font-size: var(--text-size-16);
  line-height: var(--text-lh-16);
  font-weight: 600;
  color: var(--color-black);
}

.tma-portal-sig-wizard__section-desc {
  margin: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-text-secondary);
}

.tma-portal-sig-wizard__only-signer {
  flex-shrink: 0;
}

.tma-portal-sig-wizard__doc-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  width: 168px;
}

.tma-portal-sig-wizard__doc-thumb {
  position: relative;
}

.tma-portal-sig-wizard__doc-remove {
  position: absolute;
  top: -8px;
  right: -8px;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border: 0;
  border-radius: 50%;
  background: var(--color-black);
  cursor: pointer;
}

.tma-portal-sig-wizard__doc-remove img {
  width: 12px;
  height: 12px;
  filter: invert(1);
}

.tma-portal-sig-wizard__doc-preview {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  min-height: 196px;
  padding: var(--space-12);
  border: 1px solid var(--color-border-soft);
  border-radius: var(--radius-12);
  background: var(--color-bg-card);
}

.tma-portal-sig-wizard__doc-preview-title {
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  font-weight: 600;
  color: var(--color-black);
}

.tma-portal-sig-wizard__doc-preview-line {
  display: block;
  height: 6px;
  border-radius: var(--radius-pill, 80px);
  background: rgba(0, 0, 0, 0.08);
}

.tma-portal-sig-wizard__doc-preview-line--short {
  width: 72%;
}

.tma-portal-sig-wizard__doc-name {
  margin: 0;
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-black);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tma-portal-sig-wizard__recipient {
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
  padding: var(--space-16);
  border: 1px solid var(--color-border-soft);
  border-radius: var(--radius-16);
  background: var(--color-white);
}

.tma-portal-sig-wizard__recipient-label {
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-text-secondary);
}

.tma-portal-sig-wizard__recipient-fields {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-16);
}

.tma-portal-sig-wizard__recipient-fields .tma-portal-field {
  max-width: none;
}

.tma-portal-sig-wizard__recipient-fields .tma-portal-input,
.tma-portal-sig-wizard__recipient-fields .tma-portal-select {
  max-width: none;
}

.tma-portal-sig-wizard--review .tma-portal-sig-wizard__body {
  flex: 1 1 auto;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-24) var(--space-32);
  overflow: auto;
}

.tma-portal-sig-wizard__review-step {
  width: 100%;
  max-width: 560px;
  margin: 0 auto;
}

.tma-portal-sig-wizard__review-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
}

.tma-portal-sig-wizard__review-form .tma-portal-field__label {
  font-weight: 600;
  color: var(--color-black);
}

.tma-portal-sig-wizard__review-form .tma-portal-input {
  max-width: none;
  width: 100%;
}

.tma-portal-sig-wizard__storage-field .tma-portal-field__label {
  display: block;
  margin-bottom: var(--space-12);
}

.tma-portal-sig-wizard__storage-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-16);
  padding: var(--space-14) var(--space-16);
  border: 1px solid var(--color-border-soft);
  border-radius: var(--radius-12);
  background: var(--color-white);
}

.tma-portal-sig-wizard__storage-pick {
  display: inline-flex;
  align-items: center;
  gap: var(--space-10);
  min-width: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-black);
}

.tma-portal-sig-wizard__storage-pick img {
  flex-shrink: 0;
}

.tma-portal-sig-wizard__storage-row .tma-portal-link {
  flex-shrink: 0;
  padding: 0;
  border: 0;
  background: transparent;
  font-family: inherit;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  font-weight: 600;
  color: var(--color-accent);
  cursor: pointer;
}

.tma-portal-sig-wizard__storage-row .tma-portal-link:hover {
  text-decoration: underline;
}

.tma-portal-sig-wizard__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-12);
  flex-shrink: 0;
  margin-top: auto;
  padding: var(--space-16) var(--space-24);
  border-top: 1px solid var(--color-border-soft);
  background: var(--color-bg-card);
}

.tma-portal-sig-wizard__foot .tma-no-data__btn.tma-portal-btn--ghost {
  border: 1px solid var(--color-accent);
  color: var(--color-accent);
  background: var(--color-white);
}

.tma-portal-sig-wizard--place-fields .tma-portal-sig-wizard__body {
  flex: 1 1 auto;
  min-height: 0;
  padding: 0;
  gap: 0;
  overflow: hidden;
}

.tma-portal-sig-wizard__workspace {
  display: grid;
  grid-template-columns: 220px minmax(0, 1fr) 168px;
  flex: 1 1 auto;
  min-height: 0;
  height: auto;
}

.tma-portal-sig-wizard__fields-panel {
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
  padding: var(--space-20) var(--space-16);
  border-right: 1px solid var(--color-border-soft);
  background: var(--color-white);
  min-width: 0;
}

.tma-portal-sig-wizard__fields-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}

.tma-portal-sig-wizard__fields-title {
  margin: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  font-weight: 600;
  color: var(--color-black);
}

.tma-portal-sig-wizard__fields-desc {
  margin: 0;
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-text-secondary);
}

.tma-portal-sig-wizard__field-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.tma-portal-sig-wizard__field-card {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  width: 100%;
  padding: var(--space-12);
  border: 1px solid var(--color-border-soft);
  border-radius: var(--radius-12);
  background: var(--color-white);
  font-family: inherit;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-black);
  text-align: left;
  cursor: pointer;
}

.tma-portal-sig-wizard__field-card:hover {
  background: var(--color-hover);
  border-color: var(--color-border-medium);
}

.tma-portal-sig-wizard__field-card-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  flex-shrink: 0;
}

.tma-portal-sig-wizard__field-card-icon img {
  width: 20px;
  height: 20px;
  opacity: 0.75;
}

.tma-portal-sig-wizard__canvas {
  min-width: 0;
  background: #ececef;
  overflow: hidden;
}

.tma-portal-sig-wizard__canvas-scroll {
  height: 100%;
  overflow: auto;
  padding: var(--space-24);
}

.tma-portal-sig-wizard__doc-sheet {
  width: min(100%, 720px);
  margin: 0 auto;
  padding: var(--space-28) var(--space-32);
  border: 1px solid var(--color-border-soft);
  border-radius: var(--radius-8);
  background: var(--color-white);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-black);
}

.tma-portal-sig-wizard__doc-sheet--art {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 420px;
}

.tma-portal-sig-wizard__doc-brand {
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--color-text-secondary);
}

.tma-portal-sig-wizard__doc-heading {
  margin: var(--space-12) 0 var(--space-16);
  font-size: var(--text-size-16);
  line-height: var(--text-lh-16);
  font-weight: 600;
}

.tma-portal-sig-wizard__doc-meta {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: var(--space-16);
  font-size: var(--text-size-12);
}

.tma-portal-sig-wizard__doc-meta th,
.tma-portal-sig-wizard__doc-meta td {
  padding: var(--space-4) var(--space-8);
  border: 1px solid var(--color-border-soft);
  text-align: left;
  font-weight: 400;
}

.tma-portal-sig-wizard__doc-meta th {
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  width: 18%;
}

.tma-portal-sig-wizard__doc-subhead {
  margin: var(--space-16) 0 var(--space-8);
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  font-weight: 600;
}

.tma-portal-sig-wizard__doc-copy {
  margin: 0 0 var(--space-12);
  color: var(--color-text-secondary);
}

.tma-portal-sig-wizard__doc-list {
  margin: 0;
  padding-left: var(--space-20);
  color: var(--color-text-secondary);
}

.tma-portal-sig-wizard__logo-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-12);
}

.tma-portal-sig-wizard__logo-leaf {
  width: 96px;
  height: 96px;
  border-radius: 50% 50% 50% 0;
  background: linear-gradient(135deg, #71dd8c, #2f9e44);
  transform: rotate(-45deg);
}

.tma-portal-sig-wizard__logo-text {
  font-size: var(--text-size-18);
  line-height: var(--text-lh-18);
  font-weight: 600;
  color: #2f9e44;
}

.tma-portal-sig-wizard__pages-panel {
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
  padding: var(--space-16) var(--space-12);
  border-left: 1px solid var(--color-border-soft);
  background: var(--color-white);
  min-width: 0;
}

.tma-portal-sig-wizard__pages-title {
  margin: 0;
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  font-weight: 600;
  color: var(--color-black);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tma-portal-sig-wizard__page-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.tma-portal-sig-wizard__page-thumb {
  display: block;
  width: 100%;
  padding: var(--space-4);
  border: 2px solid transparent;
  border-radius: var(--radius-8);
  background: transparent;
  cursor: pointer;
}

.tma-portal-sig-wizard__page-thumb.is-active {
  border-color: var(--color-black);
}

.tma-portal-sig-wizard__page-mini {
  display: block;
  width: 100%;
  aspect-ratio: 0.77;
  border: 1px solid var(--color-border-soft);
  border-radius: var(--radius-4);
  background: var(--color-white);
}

.tma-portal-sig-wizard__page-mini--brief {
  background:
    linear-gradient(var(--color-bg-card) 12px, transparent 12px) 0 8px / 100% 18px repeat-y,
    var(--color-white);
}

.tma-portal-sig-wizard__page-mini--logo {
  background:
    radial-gradient(circle at 50% 42%, #71dd8c 0 18%, transparent 19%),
    var(--color-white);
}

@media (max-width: 900px) {
  .tma-portal-sig-wizard__head {
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "title close"
      "steps steps";
  }

  .tma-portal-sig-wizard__title { grid-area: title; }
  .tma-portal-sig-wizard__close { grid-area: close; }
  .tma-portal-sig-wizard__steps {
    grid-area: steps;
    justify-content: flex-start;
    overflow-x: auto;
  }

  .tma-portal-sig-wizard__recipient-fields {
    grid-template-columns: 1fr;
  }

  .tma-portal-sig-wizard__workspace {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr auto;
  }

  .tma-portal-sig-wizard__fields-panel {
    border-right: 0;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .tma-portal-sig-wizard__field-list {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .tma-portal-sig-wizard__field-card {
    flex: 1 1 140px;
  }

  .tma-portal-sig-wizard__pages-panel {
    border-left: 0;
    border-top: 1px solid var(--color-border-soft);
  }

  .tma-portal-sig-wizard__page-list {
    flex-direction: row;
  }

  .tma-portal-sig-wizard__page-thumb {
    width: 72px;
  }
}

.tma-portal-sig-card__main {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  min-width: 0;
}

.tma-portal-sig-card__title {
  margin: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  font-weight: 400;
  color: var(--color-black);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.tma-portal-sig-card__meta {
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.tma-portal-sig-card__assign {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  min-width: 0;
}

.tma-portal-sig-card__assign-label {
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.tma-portal-sig-card__assign-name {
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-black);
  white-space: nowrap;
}

.tma-portal-sig-card__avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  font-size: 10px;
  line-height: 1;
  font-weight: 600;
  color: var(--color-black);
  flex-shrink: 0;
}

@media (max-width: 720px) {
  .tma-portal-sig-card {
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-12);
  }

  .tma-portal-sig-card__actions {
    justify-content: flex-start;
  }
}

.tma-portal-page--signatures .tma-portal-toolbar {
  margin-top: var(--space-4);
}
.tma-portal-avatar-cell { display: inline-flex; align-items: center; gap: var(--space-8); min-width: 0; max-width: 100%; }
.tma-portal-avatar-cell img { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; }

/* file name - edit icon only when hovering the name */
.tma-portal-file-name {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
  min-width: 0;
  max-width: 100%;
}

.tma-portal-file-name__text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: var(--tma-table-font-weight-regular, 400);
}

.tma-portal-file-name__edit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  padding: 0;
  border: 0;
  border-radius: var(--radius-8);
  background: transparent;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.12s ease, background 0.12s ease;
}

.tma-portal-file-name__edit img {
  width: 16px;
  height: 16px;
  opacity: 0.7;
}

.tma-portal-file-name:hover .tma-portal-file-name__edit,
.tma-portal-file-name:focus-within .tma-portal-file-name__edit {
  opacity: 1;
  pointer-events: auto;
}

.tma-portal-file-name__edit:hover { background: var(--color-hover); }