# tma-portal — Apache rewrites for clean URLs and dashboard route reloads.
# Document root should point at this public/ directory.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Avoid extensionless path conflicts (e.g. /overview matching overview.*)
    Options -MultiViews

    # Serve real files (css, js, images, demo/*.html, etc.)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Only serve directories that have their own index.html (not /email/, /css/, etc.)
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
    RewriteRule ^ - [L]

    # Map extensionless paths to nested index.html (e.g. /sign-in, /settings/change-email)
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
    RewriteRule ^(.+?)/?$ $1/index.html [L]

    # Dashboard client-side routes (/overview, /clients/new, /email, etc.)
    RewriteRule ^ index.html [L]
</IfModule>

DirectoryIndex index.html

# Prevent directory listings when index.html is missing
Options -Indexes
