  align-items: center;
  justify-content: center;
  padding: var(--space-20);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.4) 100%),
    rgba(0, 0, 0, 0.2);
  background-color: #000;
}

.tma-dash__email-template-pricing-decor {
  position: absolute;
  opacity: 0.85;
  pointer-events: none;
}

.tma-dash__email-template-pricing-decor--1 {
  width: 56px;
  height: 56px;
  top: 16%;
  right: 10%;
}

.tma-dash__email-template-pricing-decor--2 {
  width: 40px;
  height: 40px;
  bottom: 18%;
  right: 24%;
}

.tma-dash__email-template-pricing-decor--3 {
  width: 32px;
  height: 32px;
  bottom: 14%;
  left: 14%;
}

.tma-dash__email-template-pricing-hero-copy {
  position: relative;
  z-index: 1;
