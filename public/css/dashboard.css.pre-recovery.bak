/* ── Notifications & Activities popups (32546:96099) ── */

.tma-dash__header-popups[hidden],
.tma-dash__header-popup[hidden] {
  display: none !important;
}

.tma-dash__header-popups {
  position: fixed;
  z-index: 120;
  display: flex;
  flex-direction: column;
  gap: var(--space-28);
  width: 320px;
  max-width: calc(100vw - 32px);
  pointer-events: none;
  padding-bottom: var(--space-4);
  scrollbar-width: thin;
}

.tma-dash__header-popups:not([hidden]) {
  pointer-events: auto;
}

.tma-dash__header-popup {
  position: relative;
  flex: 0 0 auto;
  isolation: isolate;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-16);
  border-radius: var(--radius-24);
  background: rgba(255, 255, 255, 0.42);
  border: 1px solid rgba(255, 255, 255, 0.38);
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
  -webkit-backdrop-filter: blur(20px) saturate(165%);
  backdrop-filter: blur(20px) saturate(165%);
  font-feature-settings: "ss01" 1, "cv01" 1;
  animation: tma-dash-header-popup-in 0.18s ease-out;
}

.tma-dash__header-popup::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(
    155deg,
    rgba(255, 255, 255, 0.28) 0%,
    rgba(255, 255, 255, 0.04) 38%,
    rgba(255, 255, 255, 0.1) 100%
  );
  pointer-events: none;
}

.tma-dash__header-popup::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
  pointer-events: none;
}

.tma-dash__header-popup > * {
  position: relative;
  z-index: 1;
}

@keyframes tma-dash-header-popup-in {
  from {
    opacity: 0;
    transform: translateY(-8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tma-dash__header-popup-heading {
  margin: 0;
  padding: var(--space-8) var(--space-4);
  font-size: 18px;
  line-height: 28px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-black);
}

.tma-dash__header-popup-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.tma-dash__header-popup-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  padding: var(--space-8);
  border-radius: var(--radius-12);
  transition: background 0.15s ease;
}

.tma-dash__header-popup-item--active,
.tma-dash__header-popup-item:hover {
  background: rgba(255, 255, 255, 0.28);
}

.tma-dash__header-popup-icon {
  flex: 0 0 28px;
  width: 28px;
  height: 28px;
  display: grid;
  place-items: center;
  border-radius: var(--radius-8);
  background: rgba(255, 255, 255, 0.35);
  border: 0.5px solid rgba(255, 255, 255, 0.25);
  -webkit-backdrop-filter: blur(8px);
  backdrop-filter: blur(8px);
}

.tma-dash__header-popup-icon img {
  width: 20px;
  height: 20px;
}

.tma-dash__header-popup-avatar {
  flex: 0 0 24px;
  width: 24px;
  height: 24px;
  border-radius: var(--radius-pill);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.25);
  border: 0.5px solid rgba(255, 255, 255, 0.3);
}

.tma-dash__header-popup-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tma-dash__header-popup-copy {
  min-width: 0;
  flex: 1 1 auto;
}

.tma-dash__header-popup-title {
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-black);
}

.tma-dash__header-popup-meta {
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: rgba(0, 0, 0, 0.4);
}

.tma-dash[data-theme="dark"] .tma-dash__header-popup,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup {
  background: rgba(24, 24, 26, 0.42);
  border-color: rgba(255, 255, 255, 0.14);
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.28);
  -webkit-backdrop-filter: blur(20px) saturate(140%);
  backdrop-filter: blur(20px) saturate(140%);
}

.tma-dash[data-theme="dark"] .tma-dash__header-popup::before,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup::before {
  background: linear-gradient(
    155deg,
    rgba(255, 255, 255, 0.1) 0%,
    rgba(255, 255, 255, 0.02) 38%,
    rgba(255, 255, 255, 0.05) 100%
  );
}

.tma-dash[data-theme="dark"] .tma-dash__header-popup::after,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup::after {
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
}

.tma-dash[data-theme="dark"] .tma-dash__header-popup-heading,
.tma-dash[data-theme="dark"] .tma-dash__header-popup-title,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup-heading,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup-title {
  color: var(--color-text-primary);
}

.tma-dash[data-theme="dark"] .tma-dash__header-popup-meta,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup-meta {
  color: var(--color-text-secondary);
}

.tma-dash[data-theme="dark"] .tma-dash__header-popup-icon,
.tma-dash[data-theme="dark"] .tma-dash__header-popup-avatar,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup-icon,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup-avatar {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.1);
}

.tma-dash[data-theme="dark"] .tma-dash__header-popup-item--active,
.tma-dash[data-theme="dark"] .tma-dash__header-popup-item:hover,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup-item--active,
.tma-dash__header-popups[data-popup-theme="dark"] .tma-dash__header-popup-item:hover {
  background: rgba(255, 255, 255, 0.08);
}

@media (max-width: 1280px) {
  .tma-dash__header-popups {
    max-width: calc(100vw - 24px);
  }
}

