  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-8) var(--space-24);
}

.tma-dash__account-settings-notify-check {
  display: inline-flex;
  align-items: center;
  gap: var(--space-8);
  font-size: 14px;
  line-height: 20px;
  color: var(--color-text-primary);
  cursor: pointer;
}

.tma-dash__account-settings-deactivate-warn {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  width: 100%;
  padding: var(--space-16);
  border-radius: var(--radius-16);
  background: rgba(255, 255, 255, 0.8);
}

.tma-dash__account-settings-deactivate-warn img {
  flex: 0 0 20px;
}

.tma-dash__account-settings-deactivate-title {
  margin: 0 0 var(--space-4);
  font-size: 14px;
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__account-settings-deactivate-desc {
  margin: 0;
  font-size: 12px;
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__account-settings-deactivate-desc a {
  color: var(--color-indigo, #adadfb);
  text-decoration: none;
}

.tma-dash__account-settings-deactivate-confirm {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  padding: 0 var(--space-12);
  font-size: 14px;
  line-height: 20px;
  color: var(--color-text-primary);
  cursor: pointer;
}

.tma-dash[data-theme="dark"] .tma-dash__account-settings-callout,
.tma-dash[data-theme="dark"] .tma-dash__account-settings-deactivate-warn {
