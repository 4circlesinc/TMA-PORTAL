}

.tma-dash__account-security-stat-label {
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-text-primary);
}

.tma-dash__account-security-stat-value {
  font-size: var(--text-size-18);
  line-height: var(--text-lh-18);
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__account-security-stat-sep {
  width: 1px;
  height: 52px;
  background: var(--color-border-soft);
  flex-shrink: 0;
}

.tma-dash__account-security-chart-wrap {
  display: flex;
  gap: var(--space-16);
  flex: 1 1 auto;
  min-height: 160px;
}

.tma-dash__account-security-chart-y {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex-shrink: 0;
  min-height: 160px;
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
