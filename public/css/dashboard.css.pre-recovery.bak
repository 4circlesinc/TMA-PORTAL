.tma-dash__email-template-pricing-toggle {
  display: inline-flex;
  align-items: center;
  padding: var(--space-4);
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.12);
  gap: var(--space-4);
}

.tma-dash__email-template-pricing-toggle-opt {
  padding: var(--space-6) var(--space-12);
  border-radius: var(--radius-full);
  font-size: var(--font-size-12);
  font-weight: var(--font-weight-medium);
  color: rgba(255, 255, 255, 0.7);
}

.tma-dash__email-template-pricing-toggle-opt--active {
  background: #fff;
