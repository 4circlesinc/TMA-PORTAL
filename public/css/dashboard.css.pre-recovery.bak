  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__account-detail-value-wrap {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-8);
}

.tma-dash__pill {
  display: inline-flex;
  align-items: center;
  padding: 2px var(--space-8);
  border-radius: var(--radius-pill);
  font-size: 12px;
  line-height: 16px;
  white-space: nowrap;
  border: 0.5px solid currentColor;
  background: color-mix(in srgb, currentColor 10%, transparent);
}

.tma-dash__pill--green { color: var(--chart-green, #71dd8c); }
.tma-dash__pill--purple { color: var(--chart-purple, #b899eb); }
.tma-dash__pill--blue { color: var(--chart-blue, #7dbbff); }
.tma-dash__pill--orange { color: var(--chart-orange, #ffb55b); }

.tma-dash__account-promo-copy {
  flex: 1 1 auto;
  min-width: 0;
}

.tma-dash__account-promo-title {
  margin: 0 0 var(--space-16);
  font-size: 14px;
  line-height: 20px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__account-promo-actions {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  flex-wrap: wrap;
}

.tma-dash__account-promo-link {
  border: 0;
  background: transparent;
  padding: 0;
  font: inherit;
  font-size: 12px;
  line-height: 16px;
  color: var(--color-text-secondary);
  cursor: pointer;
}

.tma-dash__account-promo-btn {
  border: 0;
  min-height: 24px;
  padding: var(--space-4) var(--space-12);
  border-radius: var(--radius-12);
  background: var(--color-black);
  color: var(--color-white);
  font: inherit;
  font-size: 12px;
  line-height: 16px;
  cursor: pointer;
}

.tma-dash__account-promo-art {
  flex-shrink: 0;
  width: 100px;
  height: 75px;
  object-fit: contain;
}

.tma-dash__account-stub-text {
  margin: 0;
  font-size: 12px;
  line-height: 16px;
  color: var(--color-text-secondary);
}

/* ── Account Settings (Figma 32546:96111) ──────── */

.tma-dash__account-panel--settings {
  gap: var(--space-28);
}

.tma-dash__account-block--settings {
  flex: 1 1 100%;
  min-width: min(100%, 800px);
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.tma-dash__account-settings-head {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
