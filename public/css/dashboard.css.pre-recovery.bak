}

.tma-dash__email-template-row {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  width: 100%;
  padding: var(--space-12) var(--space-16);
  border: 0;
  background: transparent;
  text-align: left;
  cursor: pointer;
}

.tma-dash__email-template-row:hover {
  background: var(--color-bg-secondary);
}

.tma-dash__email-template-row--active {
  background: var(--color-bg-secondary);
}

.tma-dash__email-template-thumb {
  flex: 0 0 40px;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-8);
}

.tma-dash__email-template-thumb--gradient {
  background:
    linear-gradient(135deg, rgba(99, 102, 241, 0.35) 0%, rgba(236, 72, 153, 0.35) 100%),
    var(--color-bg-tertiary);
}

.tma-dash__email-template-thumb--product {
  background: var(--color-bg-tertiary) url('../images/design-system/snowui-icon.png') center / 24px no-repeat;
}

.tma-dash__email-template-category {
  flex: 0 0 auto;
  font-size: var(--font-size-12);
  color: var(--color-text-tertiary);
}

.tma-dash__email-detail--template .tma-dash__email-detail-subject {
  padding-bottom: var(--space-8);
}

.tma-dash__email-template-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-12);
