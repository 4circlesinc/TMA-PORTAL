  gap: var(--space-16);
  min-width: 0;
  padding: 0 var(--space-12);
}

.tma-dash__account-settings-connect-icon {
  flex: 0 0 32px;
  width: 32px;
  height: 32px;
  object-fit: contain;
}

.tma-dash__account-settings-connect-copy {
  min-width: 0;
}

.tma-dash__account-settings-connect-title {
  margin: 0;
  font-size: 14px;
  line-height: 20px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__account-settings-connect-desc {
  margin: 0;
  font-size: 12px;
  line-height: 16px;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tma-dash__account-settings-connect-switch {
  flex: 0 0 auto;
  padding: 0 var(--space-12);
}

.tma-dash__account-settings-pref,
.tma-dash__account-settings-notify-row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: var(--space-16);
  width: 100%;
  padding: 0 var(--space-12) var(--space-16);
}

.tma-dash__account-settings-pref--border,
.tma-dash__account-settings-notify-row--border {
  border-bottom: 1px solid var(--color-overlay-10);
}

.tma-dash__account-settings-pref-check,
.tma-dash__account-settings-notify-checks .tma-forms-guidance-page__control {
  flex: 0 0 auto;
}

.tma-dash__account-settings-pref-check .tma-forms-guidance-page__control,
.tma-dash__account-settings-pref .tma-forms-guidance-page__control,
.tma-dash__account-settings-notify-check .tma-forms-guidance-page__control,
.tma-dash__account-settings-deactivate-confirm .tma-forms-guidance-page__control {
  width: 20px;
  height: 20px;
  padding: 0;
  border: 0;
  background: transparent;
}

.tma-dash__account-settings-pref-check .tma-forms-guidance-page__control-svg,
.tma-dash__account-settings-notify-check .tma-forms-guidance-page__control-svg,
.tma-dash__account-settings-deactivate-confirm .tma-forms-guidance-page__control-svg {
  width: 20px;
  height: 20px;
}

.tma-dash__account-settings-pref-copy {
  flex: 1 1 240px;
  min-width: 0;
}

.tma-dash__account-settings-pref-title {
