/* ── Account — Logs (Figma 32546:96109) ── */

.tma-dash__account-panel--logs .tma-table-b-sessions {
  width: 100%;
  min-width: 0;
  border-radius: var(--radius-20);
}

.tma-dash__account-block--logs {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.tma-dash__account-logs-sheet {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.tma-dash__account-logs-row {
  display: grid;
  grid-template-columns: 174px 1fr auto;
  align-items: stretch;
  width: 100%;
  min-height: 40px;
}

.tma-dash__account-logs-cell {
  display: flex;
  align-items: center;
  min-height: 40px;
  padding: var(--space-8) var(--space-12) var(--space-8) 0;
  box-sizing: border-box;
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-text-primary);
  border-bottom: 1px solid var(--color-hover);
}

.tma-dash__account-logs-cell--path {
  padding-right: var(--space-12);
  min-width: 0;
  word-break: break-word;
}

.tma-dash__account-logs-cell--action {
  justify-content: center;
  padding: var(--space-4) var(--space-12);
}

.tma-dash__account-logs-row--last .tma-dash__account-logs-cell {
  border-bottom: 0;
}

.tma-dash__account-logs-download {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: 0;
  border: 0;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-dash__account-logs-download:hover {
  background: var(--color-hover);
}

.tma-dash__account-logs-download img {
  display: block;
  width: 16px;
  height: 16px;
}

@media (max-width: 900px) {
  .tma-dash__account-logs-row {
    grid-template-columns: minmax(120px, 174px) 1fr auto;
  }
}

