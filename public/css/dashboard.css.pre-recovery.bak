}

.tma-dash[data-theme="dark"] .tma-dash__account-settings-callout img,
.tma-dash[data-theme="dark"] .tma-dash__account-settings-deactivate-warn img {
  filter: invert(1) brightness(1.6);
}

.tma-dash[data-theme="dark"] .tma-dash__account-settings-btn--primary {
  background: var(--color-white);
  color: var(--color-black);
}

.tma-dash[data-theme="dark"] .tma-dash__account-stat-divider {
  background: rgba(255, 255, 255, 0.12);
}

@media (max-width: 900px) {
  .tma-dash__account-block--profile {
