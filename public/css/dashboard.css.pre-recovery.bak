  width: 100%;
  min-height: 140px;
  aspect-ratio: auto;
}

.tma-dash__account-security-chart-x {
  display: flex;
  justify-content: space-between;
  gap: var(--space-8);
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-text-secondary);
