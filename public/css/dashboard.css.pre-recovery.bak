  cursor: pointer;
}

.tma-dash__account-billing-cards {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-16);
  align-items: stretch;
  width: 100%;
}

/* Payment Methods — Figma 32546:96113 */
.tma-dash__account-billing-cards--payment .tma-card--credit {
  flex: 1 0 200px;
  width: auto;
  min-width: 200px;
  max-width: 280px;
  height: 140px;
  min-height: 140px;
  padding: 16px 24px;
  border: 0;
  border-radius: 16px;
  background: var(--color-surface, rgba(255, 255, 255, 0.8));
  box-sizing: border-box;
}

.tma-dash__account-billing-cards--payment .tma-card--credit .tma-card__credit-footer,
.tma-dash__account-billing-cards--payment .tma-card--credit-paypal .tma-card__credit-footer {
  margin-top: auto;
}

.tma-dash__account-billing-cards--payment .tma-card__credit-footer--brand {
  justify-content: flex-end;
}

.tma-dash__account-billing-cards--payment .tma-card--add-address {
  flex: 1 0 200px;
  width: auto;
  min-width: 200px;
  max-width: 280px;
  height: 140px;
  min-height: 140px;
  padding: 24px;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  border: 1px dashed rgba(0, 0, 0, 0.2);
  border-radius: 16px;
  background: transparent;
  color: rgba(0, 0, 0, 0.4);
}

.tma-dash__account-billing-cards--payment .tma-card__add-address-icon,
.tma-dash__account-billing-cards--payment .tma-card__add-address-icon-svg {
  display: block;
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.tma-dash__account-billing-cards--payment .tma-card__add-address-label {
  font-size: 14px;
  line-height: 20px;
}

/* Billing Address — Figma 32546:96113 */
.tma-dash__account-billing-cards--address .tma-card--address {
  flex: 1 0 200px;
  width: auto;
  min-width: 200px;
  max-width: 280px;
  padding: 16px 24px;
  border: 0;
  border-radius: 16px;
  background: var(--color-surface, rgba(255, 255, 255, 0.8));
  box-sizing: border-box;
}

.tma-dash__account-billing-cards--address .tma-card--address-active {
  background: #fff;
  border: 1px solid rgba(0, 0, 0, 0.1);
  padding: 15px 23px;
}

.tma-dash__account-billing-cards--address .tma-card--add-address {
  flex: 1 0 200px;
  width: auto;
  min-width: 200px;
  max-width: 280px;
  min-height: 120px;
  padding: 24px;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: var(--space-8);
  border: 1px dashed rgba(0, 0, 0, 0.2);
  border-radius: 16px;
  background: transparent;
}

.tma-dash__account-filter-tabs {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-16);
}

.tma-dash__account-filter-tab {
  border: 0;
  background: transparent;
  padding: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-text-primary);
  opacity: 0.4;
  cursor: pointer;
}

.tma-dash__account-filter-tab.is-active {
  opacity: 1;
}

.tma-dash__account-sheet {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.tma-dash__account-sheet-row {
  display: grid;
  grid-template-columns: var(--account-sheet-columns);
  align-items: stretch;
  width: 100%;
  min-height: 40px;
}

.tma-dash__account-sheet-cell {
  display: flex;
  align-items: center;
  min-height: 40px;
  padding: var(--space-8) var(--space-12) var(--space-8) 0;
  box-sizing: border-box;
  font-size: var(--text-size-12);
  line-height: var(--text-lh-12);
  color: var(--color-text-primary);
}

.tma-dash__account-sheet-cell--head {
  color: var(--color-text-muted);
  border-bottom: 1px solid rgba(0, 0, 0, 0.2);
}

.tma-dash__account-sheet-row:not(.tma-dash__account-sheet-row--head):not(.tma-dash__account-sheet-row--last) .tma-dash__account-sheet-cell {
  border-bottom: 1px solid var(--color-hover);
}

.tma-dash__account-sheet-manager {
  display: inline-flex;
  align-items: center;
  gap: var(--space-8);
  min-width: 0;
}

.tma-dash__account-sheet-avatar {
  display: block;
  width: 24px;
  height: 24px;
  border-radius: var(--radius-80);
  object-fit: cover;
  flex-shrink: 0;
}

.tma-dash__account-sheet-pdf {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
}

.tma-dash__account-sheet-pdf img {
  display: block;
  width: 16px;
  height: 16px;
}

/* ── Account — Referrals (Figma 32546:96110) ── */

.tma-dash__account-referrals-stats {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-28);
  padding-bottom: var(--space-16);
  border-bottom: 1px solid var(--color-hover);
}

.tma-dash__account-referrals-stat {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.tma-dash__account-referrals-stat-label {
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-text-primary);
}

.tma-dash__account-referrals-stat-value {
  font-size: var(--text-size-18);
  line-height: var(--text-lh-18);
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__account-referrals-stat-sep {
  width: 1px;
  height: 52px;
  background: var(--color-hover);
  flex-shrink: 0;
}

.tma-dash__account-referrals-subtitle {
  margin: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__account-referrals-link {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  min-height: 40px;
  padding: var(--space-4) var(--space-12);
  border: 0.5px solid rgba(0, 0, 0, 0.2);
  border-radius: var(--radius-12);
  background: var(--color-surface, rgba(255, 255, 255, 0.8));
}

.tma-dash__account-referrals-link-text {
  flex: 1;
  min-width: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-text-primary);
  word-break: break-word;
}

.tma-dash__account-referrals-copy {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: 0;
  border: 0;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
  flex-shrink: 0;
}

.tma-dash__account-referrals-copy:hover {
  background: var(--color-hover);
}

.tma-dash__account-referrals-action-row,
.tma-dash__account-referrals-withdraw {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-16);
}

.tma-dash__account-referrals-action-copy,
.tma-dash__account-referrals-withdraw-copy {
  flex: 1 1 240px;
  min-width: 0;
}

.tma-dash__account-referrals-withdraw {
  padding: var(--space-16);
  border-radius: var(--radius-16);
  background: var(--color-surface, rgba(255, 255, 255, 0.8));
}

.tma-dash__account-referrals-withdraw-main {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  flex: 1 1 240px;
  min-width: 0;
}

/* ── Account — Statements (Figma 32546:96107) ── */

.tma-dash__account-block--statements-earnings,
.tma-dash__account-block--statements-invoices {
  flex: 1 1 min(100%, 400px);
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.tma-dash__account-block--statements-invoices {
  min-height: 192px;
}

.tma-dash__account-statements-stats {
  padding-bottom: 0;
  border-bottom: 0;
}

.tma-dash__account-statements-invoices-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  width: 100%;
}

.tma-dash__account-statements-select {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-8);
  min-height: 40px;
  padding: var(--space-4) var(--space-12);
  border: 0.5px solid rgba(0, 0, 0, 0.2);
  border-radius: var(--radius-12);
  background: var(--color-surface, rgba(255, 255, 255, 0.8));
  cursor: pointer;
}

.tma-dash__account-statements-select-label {
  flex: 1;
  min-width: 0;
  font-size: var(--text-size-14);
  line-height: var(--text-lh-14);
  color: var(--color-text-primary);
}

.tma-dash__account-statements-select img {
  display: block;
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.tma-dash__account-statements-download {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36px;
  min-height: 36px;
  padding: var(--space-8);
  border: 0;
  border-radius: var(--radius-12);
  background: rgba(0, 0, 0, 0.04);
  cursor: pointer;
  flex-shrink: 0;
}

.tma-dash__account-statements-download:hover {
  background: var(--color-hover);
}

.tma-dash__account-statements-download img {
  display: block;
  width: 20px;
  height: 20px;
}

.tma-dash__account-block--statements-table {
  width: 100%;
  flex: 1 1 100%;
}

.tma-dash__account-sheet-amount--negative {
  color: #adadfb;
}

@media (max-width: 900px) {
  .tma-dash__account-referrals-stat-sep {
    display: none;
  }

  .tma-dash__account-sheet-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .tma-dash__account-sheet-row--head {
    display: none;
  }
}

/* ── Account — API Keys (Figma 32546:96112) ── */

.tma-dash__account-panel--api-keys {
  display: flex;
  flex-direction: column;
  gap: var(--space-28);
}

.tma-dash__account-panel--api-keys .tma-table-b-sessions {
  width: 100%;
  min-width: 0;
  border-radius: var(--radius-20);
}

.tma-dash__account-block--api-keys-overview,
.tma-dash__account-block--api-keys-table {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  width: 100%;
}

.tma-dash__account-block--api-keys-table {
  gap: var(--space-4);
}

.tma-dash__account-block--api-keys-table .tma-table-b-sessions {
  border-radius: 0;
  background: transparent;
  padding: 0;
}

.tma-dash__account-api-keys-action-row--border {
  padding-bottom: var(--space-16);
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

/* ─────────────────────────────────────────
 * EMAIL page (Figma 32546:96144)
 * ───────────────────────────────────────── */

.tma-dash__view[data-view="email"]:not([hidden]) {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.tma-dash__view[data-view="messages"]:not([hidden]) {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.tma-dash__email {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.tma-dash__email-layout {
  display: flex;
  align-items: stretch;
  gap: var(--space-24);
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.tma-dash__email-folders {
  flex: 0 0 124px;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  padding: var(--space-16) 0;
  min-height: 0;
}

.tma-dash__email-folder {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  width: 100%;
  padding: var(--space-8);
  border: none;
  border-radius: var(--radius-8);
  background: transparent;
  color: var(--color-text-primary);
  font: inherit;
  font-size: var(--text-size-14);
  line-height: 20px;
  text-align: left;
  cursor: pointer;
}

.tma-dash__email-folder img {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  opacity: 0.6;
}

.tma-dash__email-folder:hover {
  background: var(--color-hover);
}

.tma-dash__email-folder--active {
  background: var(--color-hover);
}

.tma-dash__email-folder--compose {
  background: var(--color-bg-tag);
}

.tma-dash__email-folder--compose.tma-dash__email-folder--active {
  background: var(--color-bg-tag);
}

.tma-dash__email-folder--compose img {
  opacity: 1;
}

.tma-dash__email-list {
  flex: 0 0 320px;
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-16);
  background: var(--color-white);
  overflow: hidden;
}

.tma-dash__email-list-head {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  padding: var(--space-8);
  border-bottom: 1px solid var(--color-overlay-4);
}

.tma-dash__email-filter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: var(--space-4);
  margin-left: auto;
  border: none;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-dash__email-filter img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__email-filter:hover {
  background: var(--color-hover);
}

.tma-dash__email-list-body {
  flex: 1;
  overflow: auto;
  min-height: 0;
}

.tma-dash__email-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  width: 100%;
  padding: var(--space-8);
  padding-bottom: var(--space-16);
  border: none;
  border-bottom: 1px solid var(--color-overlay-4);
  background: transparent;
  color: inherit;
  font: inherit;
  text-align: left;
  cursor: pointer;
}

.tma-dash__email-row:hover {
  background: var(--color-hover);
}

.tma-dash__email-row--active {
  background: var(--color-hover);
}

.tma-dash__email-row-icon,
.tma-dash__email-row-avatar {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tma-dash__email-row-avatar {
  background: var(--color-hover);
}

.tma-dash__email-row-icon img,
.tma-dash__email-row-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tma-dash__email-row-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.tma-dash__email-row-sender {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__email-row-preview {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tma-dash__email-row-time {
  flex-shrink: 0;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__email-detail {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  position: relative;
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-16);
  background: var(--color-white);
  overflow: hidden;
}

.tma-dash__email-detail--empty {
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
}

.tma-dash__email-detail-subject {
  margin: 0 var(--space-16);
  padding: var(--space-12) var(--space-16);
  background: var(--color-bg-card);
  border-radius: var(--radius-16);
  font-size: var(--text-size-14);
  font-weight: 600;
  line-height: 20px;
}

.tma-dash__email-detail-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: var(--space-8) var(--space-16);
  margin: var(--space-8) var(--space-16) 0;
  padding: var(--space-12) var(--space-16);
  background: var(--color-bg-card);
  border-radius: var(--radius-16);
}

.tma-dash__email-detail-from {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  flex: 1;
  min-width: 0;
}

.tma-dash__email-detail-from-text {
  display: flex;
  flex-direction: column;
  gap: 0;
  min-width: 0;
}

.tma-dash__email-detail-from-line {
  font-size: var(--text-size-14);
  line-height: 20px;
}

.tma-dash__email-detail-sep {
  color: var(--color-text-placeholder);
}

.tma-dash__email-detail-date {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-secondary);
}

.tma-dash__email-detail-actions {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-4);
  margin-left: auto;
}

.tma-dash__email-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: var(--space-4);
  border: none;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-dash__email-action img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__email-action:hover {
  background: var(--color-hover);
}

.tma-dash__email-detail-scroll {
  flex: 1;
  overflow: auto;
  min-height: 0;
  padding: var(--space-16) var(--space-24) 80px;
}

.tma-dash__email-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__email-body p {
  margin: 0;
}

.tma-dash__email-cta {
  align-self: flex-start;
  padding: var(--space-8) var(--space-16);
  border: none;
  border-radius: var(--radius-16);
  background: var(--color-black);
  color: var(--color-text-white);
  font: inherit;
  font-size: var(--text-size-14);
  line-height: 20px;
  cursor: pointer;
}

.tma-dash__email-avatar-grid {
  display: grid;
  grid-template-columns: repeat(2, 40px);
  gap: 4px;
  width: fit-content;
}

.tma-dash__email-avatar-grid img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--color-white);
}

.tma-dash__email-signin-card {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-16);
  padding: var(--space-16);
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-16);
}

.tma-dash__email-signin-info {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  flex: 1;
  min-width: 0;
}

.tma-dash__email-signin-info > img {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}

.tma-dash__email-signin-title {
  font-weight: 600;
}

.tma-dash__email-signin-btn {
  padding: var(--space-8) var(--space-16);
  border: none;
  border-radius: var(--radius-16);
  background: var(--color-hover);
  font: inherit;
  font-size: var(--text-size-14);
  line-height: 20px;
  cursor: pointer;
}

.tma-dash__email-copyright {
  text-align: center;
  color: var(--color-text-secondary) !important;
}

.tma-dash__email-detail-footer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: flex-end;
  gap: var(--space-8);
  padding: var(--space-20) var(--space-24);
  border-top: 1px solid var(--color-overlay-4);
  background: var(--color-white);
}

.tma-dash__email-footer-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4) var(--space-12);
  border: none;
  border-radius: var(--radius-12);
  background: var(--color-hover);
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  cursor: pointer;
}

.tma-dash__email-footer-btn img {
  width: 16px;
  height: 16px;
}

@media (max-width: 1100px) {
  .tma-dash__email-folders {
    flex: 0 0 96px;
    padding: var(--space-12) var(--space-8);
  }

  .tma-dash__email-folder span {
    display: none;
  }

  .tma-dash__email-list {
    flex: 0 0 280px;
  }
}

@media (max-width: 860px) {
  .tma-dash__email-layout {
    flex-direction: column;
    min-height: 640px;
    overflow: auto;
  }

  .tma-dash__email-folders {
    flex: 0 0 auto;
    flex-direction: row;
    flex-wrap: wrap;
    padding: var(--space-12) 0;
  }

  .tma-dash__email-folder span {
    display: inline;
  }

  .tma-dash__email-list {
    flex: 0 0 240px;
  }
}

/* Email — compose (Figma 32546:96128) */

.tma-dash__email-compose {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  padding: var(--space-16);
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-16);
  background: var(--color-white);
  overflow: hidden;
}

.tma-dash__email-compose-headers {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 672px;
}

.tma-dash__email-compose-to,
.tma-dash__email-compose-subject {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-8) var(--space-16);
  padding: var(--space-12) var(--space-16);
  border: 1px solid var(--color-overlay-4);
  font-size: var(--text-size-14);
  line-height: 20px;
}

.tma-dash__email-compose-to {
  border-radius: var(--radius-16) var(--radius-16) 0 0;
  border-bottom: none;
}

.tma-dash__email-compose-subject {
  border-radius: 0 0 var(--radius-16) var(--radius-16);
}

.tma-dash__email-compose-label {
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.tma-dash__email-compose-recipients {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-8);
  flex: 1;
  min-width: 0;
}

.tma-dash__email-compose-expand {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 16px;
  height: 16px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
  flex-shrink: 0;
  margin-left: auto;
}

.tma-dash__email-compose-expand img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__email-compose-subject-value {
  color: var(--color-text-primary);
}

.tma-dash__email-compose-editor {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 672px;
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-16);
  overflow: hidden;
  position: relative;
}

.tma-dash__email-compose-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
  padding: var(--space-8);
  background: var(--color-bg-card);
  border-radius: var(--radius-16) var(--radius-16) 0 0;
}

.tma-dash__email-compose-toolbar-left {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-8);
  min-width: 0;
}

.tma-dash__email-compose-toolbar-group {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.tma-dash__email-compose-toolbar-sep {
  width: 1px;
  height: 20px;
  background: var(--color-border-soft);
  flex-shrink: 0;
}

.tma-dash__email-compose-tool {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  min-width: 24px;
  min-height: 24px;
  padding: var(--space-4);
  border: none;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-dash__email-compose-tool img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__email-compose-tool:hover {
  background: var(--color-hover);
}

.tma-dash__email-compose-tool--caret {
  padding-inline: var(--space-12);
}

.tma-dash__email-compose-tool-caret {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__email-compose-tool--expand {
  flex-shrink: 0;
}

.tma-dash__email-compose-body {
  flex: 1;
  overflow: auto;
  min-height: 0;
  padding: var(--space-16) var(--space-24) 80px;
}

.tma-dash__email-compose-title {
  margin: 0 0 var(--space-8);
  font-size: var(--text-size-24);
  line-height: var(--text-lh-24);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.tma-dash__email-compose-lead {
  margin: 0 0 var(--space-16);
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__email-compose-hero {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 260px;
  margin-bottom: var(--space-16);
  border-radius: var(--radius-20);
  background: var(--color-black);
  overflow: hidden;
}

.tma-dash__email-compose-hero img {
  width: 100px;
  height: 100px;
  object-fit: contain;
  opacity: 0.9;
}

.tma-dash__email-compose-signoff {
  margin: 0;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-secondary);
}

.tma-dash__email-compose-footer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
  padding: var(--space-20) var(--space-24);
  border-top: 1px solid var(--color-overlay-4);
  background: var(--color-white);
}

.tma-dash__email-compose-attach {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.tma-dash__email-compose-attach-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: var(--space-4);
  border: none;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-dash__email-compose-attach-btn img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__email-compose-attach-btn:hover {
  background: var(--color-hover);
}

.tma-dash__email-compose-send {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  margin-left: auto;
}

.tma-dash__email-compose-send-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 24px;
  padding: var(--space-4) var(--space-12);
  border: none;
  border-radius: var(--radius-12);
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  cursor: pointer;
}

.tma-dash__email-compose-send-btn--late {
  background: var(--color-hover);
  color: var(--color-text-primary);
}

.tma-dash__email-compose-send-btn--primary {
  background: var(--color-black);
  color: var(--color-text-white);
}

/* ── Messages page ─────────────────────────────── */

.tma-dash__messages {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.tma-dash__messages-layout {
  display: flex;
  align-items: stretch;
  gap: var(--space-24);
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.tma-dash__messages-list {
  flex: 0 0 320px;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  min-width: 0;
  min-height: 0;
  overflow: hidden;
  align-self: stretch;
}

.tma-dash__messages-list-head {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  padding: var(--space-8);
  background: var(--color-bg-card);
  border-radius: var(--radius-16);
  flex-shrink: 0;
}

.tma-dash__messages-list-tools {
  display: flex;
  align-items: center;
  gap: var(--space-8);
}

.tma-dash__messages-icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 24px;
  min-height: 24px;
  padding: var(--space-4);
  border: none;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-dash__messages-icon-btn:hover {
  background: var(--color-hover);
}

.tma-dash__messages-icon-btn img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__messages-search {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  flex: 1;
  min-width: 0;
  padding: var(--space-4) var(--space-8);
  background: var(--color-bg-input);
  border: 0.5px solid var(--color-border-medium);
  border-radius: var(--radius-16);
}

.tma-dash__messages-search img {
  width: 16px;
  height: 16px;
  opacity: 0.4;
  flex-shrink: 0;
}

.tma-dash__messages-search-text {
  flex: 1;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-placeholder);
}

.tma-dash__messages-list-body {
  flex: 1;
  min-height: 0;
  overflow-x: hidden;
  overflow-y: auto;
  scrollbar-width: thin;
}

.tma-dash__messages-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  width: 100%;
  padding: var(--space-8) var(--space-8) var(--space-16);
  border: none;
  border-bottom: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-16);
  background: transparent;
  font: inherit;
  text-align: left;
  cursor: pointer;
}

.tma-dash__messages-row:first-child {
  border-bottom: none;
  padding-bottom: var(--space-8);
}

.tma-dash__messages-row:hover {
  background: var(--color-hover);
}

.tma-dash__messages-row--active {
  background: var(--color-overlay-4);
}

.tma-dash__messages-row-icon,
.tma-dash__messages-row-avatar {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-overlay-4);
}

.tma-dash__messages-row-icon img,
.tma-dash__messages-row-avatar > img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tma-dash__messages-row-avatar--user img {
  width: 12px;
  height: 12px;
  margin: 6px;
  object-fit: contain;
  opacity: 0.4;
}

.tma-dash__messages-row-avatar--group {
  position: relative;
  overflow: visible;
  background: transparent;
}

.tma-dash__messages-row-avatar-part {
  position: absolute;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  object-fit: cover;
  border: 1px solid var(--color-white);
}

.tma-dash__messages-row-avatar-part--1 {
  top: 0;
  left: 0;
}

.tma-dash__messages-row-avatar-part--2 {
  right: 0;
  bottom: 0;
}

.tma-dash__messages-row-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.tma-dash__messages-row-name {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__messages-row-preview {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tma-dash__messages-row-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--space-4);
  flex-shrink: 0;
}

.tma-dash__messages-row-time {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__messages-unread {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 20px;
  padding: 1px 6px;
  border-radius: 50%;
  background: var(--color-indigo);
  color: var(--color-text-white);
  font-size: var(--text-size-12);
  line-height: 16px;
}

.tma-dash__messages-chat {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-16);
  background: var(--color-white);
  overflow: hidden;
}

.tma-dash__messages-chat--empty {
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
}

.tma-dash__messages-chat-head {
  display: flex;
  align-items: center;
  gap: var(--space-16);
  padding: var(--space-16);
  border-bottom: 1px solid var(--color-overlay-4);
}

.tma-dash__messages-chat-contact {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
  flex: 1;
  min-width: 0;
}

.tma-dash__messages-chat-contact-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.tma-dash__messages-chat-name {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__messages-chat-email {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__messages-chat-actions {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  flex-shrink: 0;
}

.tma-dash__messages-chat-body {
  flex: 1;
  overflow: auto;
  padding: var(--space-16) var(--space-24);
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.tma-dash__messages-divider {
  align-self: center;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-secondary);
}

.tma-dash__messages-bubble-row {
  display: flex;
  max-width: min(560px, 85%);
  position: relative;
}

.tma-dash__messages-bubble-row--in {
  align-self: flex-end;
}

.tma-dash__messages-bubble-row--out {
  align-self: flex-start;
}

.tma-dash__messages-bubble {
  padding: var(--space-16) var(--space-20);
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__messages-bubble--in {
  background: var(--color-1);
  border-radius: var(--radius-16) var(--radius-24) var(--radius-4) var(--radius-16);
}

.tma-dash__messages-bubble--out {
  background: var(--color-2);
  border-radius: var(--radius-24) var(--radius-16) var(--radius-16) var(--radius-4);
}

.tma-dash__messages-bubble-text p {
  margin: 0;
}

.tma-dash__messages-bubble-text p + p {
  margin-top: var(--space-8);
}

.tma-dash__messages-emoji {
  width: 32px;
  height: 32px;
}

.tma-dash__messages-heart {
  position: absolute;
  right: -8px;
  bottom: -8px;
  width: 32px;
  height: 32px;
}

.tma-dash__messages-heart img {
  width: 100%;
  height: 100%;
}

.tma-dash__messages-link-wrap {
  display: flex;
  align-items: flex-start;
  gap: var(--space-16);
}

.tma-dash__messages-link-card {
  flex: 1;
  min-width: 0;
  max-width: 560px;
  border-radius: var(--radius-20);
  overflow: hidden;
}

.tma-dash__messages-link-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 160px;
  background: linear-gradient(135deg, var(--color-1), var(--color-2));
}

.tma-dash__messages-link-visual img {
  width: 80px;
  height: 80px;
  object-fit: contain;
}

.tma-dash__messages-link-body {
  padding: var(--space-16);
  background: var(--color-bg-card);
}

.tma-dash__messages-link-url {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-indigo);
}

.tma-dash__messages-link-title {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__messages-link-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  padding-top: var(--space-8);
}

.tma-dash__messages-composer {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  margin: var(--space-16) var(--space-24);
  padding: var(--space-16) var(--space-20);
  background: var(--color-bg-input);
  border: 0.5px solid var(--color-border-medium);
  border-radius: var(--radius-16);
}

.tma-dash__messages-composer-placeholder {
  flex: 1;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-placeholder);
}

.tma-dash__messages-composer-send {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
}

.tma-dash__messages-composer-send img {
  width: 20px;
  height: 20px;
  opacity: 0.6;
}

@media (max-width: 900px) {
  .tma-dash__messages-layout {
    flex-direction: column;
    gap: var(--space-16);
  }

  .tma-dash__messages-list {
    flex: 0 0 auto;
    max-height: 280px;
  }
}

/* ── Contacts page (Figma 32546:96130) ─────────── */

.tma-dash__view[data-view="contacts"]:not([hidden]) {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.tma-dash__contacts {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.tma-dash__contacts-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: var(--space-28);
  width: 100%;
  overflow: hidden;
}

.tma-dash__contacts-layout {
  display: flex;
  align-items: stretch;
  gap: var(--space-28);
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.tma-dash__contacts-directory {
  flex: 0 0 208px;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  min-height: 0;
  padding: var(--space-24);
  background: var(--color-bg-card);
  border-radius: var(--radius-20);
  overflow: hidden;
}

.tma-dash__contacts-directory.tma-dash__contacts-directory--standalone {
  flex: 0 0 320px;
  width: 320px;
  max-width: 100%;
  align-self: stretch;
}

.tma-dash__contacts-detail {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tma-dash__contacts-directory-head {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  flex-shrink: 0;
}

.tma-dash__contacts-add-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  width: 100%;
  min-height: 32px;
  padding: var(--space-8) var(--space-12);
  border: none;
  border-radius: var(--radius-12);
  background: var(--color-black);
  color: var(--color-text-white);
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  cursor: pointer;
}

.tma-dash__contacts-add-btn:hover {
  opacity: 0.9;
}

.tma-dash__contacts-add-btn img {
  width: 16px;
  height: 16px;
  filter: brightness(0) invert(1);
}

.tma-dash__contacts-search {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  padding: var(--space-4) var(--space-8);
  background: rgba(255, 255, 255, 0.8);
  border: 0.5px solid var(--color-border-medium);
  border-radius: var(--radius-16);
  flex-shrink: 0;
}

.tma-dash__contacts-search img {
  width: 16px;
  height: 16px;
  opacity: 0.4;
  flex-shrink: 0;
}

.tma-dash__contacts-search-text {
  flex: 1;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-placeholder);
}

.tma-dash__contacts-directory-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  scrollbar-width: thin;
}

.tma-dash__contacts-letter {
  padding: var(--space-8) var(--space-12);
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-row {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  width: 100%;
  padding: var(--space-4) var(--space-8);
  border: none;
  border-radius: var(--radius-8);
  background: transparent;
  font: inherit;
  text-align: left;
  cursor: pointer;
}

.tma-dash__contacts-row:hover {
  background: var(--color-hover);
}

.tma-dash__contacts-row--active {
  background: var(--color-overlay-4);
}

.tma-dash__contacts-row-name {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-avatar {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-overlay-4);
}

.tma-dash__contacts-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tma-dash__contacts-avatar--initial {
  font-size: var(--text-size-12);
  line-height: 1;
  color: var(--color-text-white);
}

.tma-dash__contacts-avatar--blue {
  background: var(--color-blue);
}

.tma-dash__contacts-avatar--green {
  background: var(--color-green);
}

.tma-dash__contacts-main {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
  overflow: hidden;
}

.tma-dash__contacts-profile,
.tma-dash__contacts-schedule {
  background: var(--color-bg-card);
  border-radius: var(--radius-20);
  padding: var(--space-24);
}

.tma-dash__contacts-profile {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: var(--space-24);
  flex: 1;
  min-height: 0;
}

.tma-dash__contacts-profile-toolbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-16);
  width: 100%;
}

.tma-dash__contacts-profile-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
  min-width: 0;
}

.tma-dash__contacts-profile-head {
  display: flex;
  align-items: center;
  gap: var(--space-16);
}

.tma-dash__contacts-profile-name {
  font-size: 18px;
  font-weight: 600;
  line-height: 28px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-profile--form {
  overflow: hidden;
}

.tma-dash__contacts-profile-ident {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  min-width: 0;
}

.tma-dash__contacts-profile-subtitle {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-profile-tablist {
  width: 100%;
  border-bottom: 1px solid var(--color-overlay-4);
  padding-bottom: var(--space-4);
}

.tma-dash__contacts-profile-tablist .tma-tab:not(.is-active) {
  opacity: 0.4;
}

.tma-dash__contacts-profile-panel {
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
  flex: 1;
  min-height: 0;
}

.tma-dash__contacts-profile-panel[hidden] {
  display: none;
}

.tma-dash__contacts-profile-panel[data-contacts-panel="info"] .tma-dash__contacts-profile-body {
  flex: 1;
}

.tma-dash__contacts-folders-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-12);
}

.tma-dash__contacts-folders-title {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-folders-add {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4) var(--space-8);
  border: none;
  border-radius: var(--radius-8);
  background: transparent;
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  cursor: pointer;
}

.tma-dash__contacts-folders-add:hover {
  background: var(--color-hover);
  color: var(--color-text-primary);
}

.tma-dash__contacts-folders-add img {
  width: 14px;
  height: 14px;
  opacity: 0.6;
}

.tma-dash__contacts-folders {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}

.tma-dash__contacts-folder {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  width: 100%;
  padding: var(--space-12);
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-12);
  background: rgba(255, 255, 255, 0.5);
  text-align: left;
  cursor: pointer;
  font: inherit;
}

.tma-dash__contacts-folder:hover {
  background: var(--color-hover);
  border-color: var(--color-border-medium);
}

.tma-dash__contacts-folder-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-12);
  background: var(--color-overlay-4);
  flex-shrink: 0;
}

.tma-dash__contacts-folder-icon img {
  width: 20px;
  height: 20px;
  opacity: 0.7;
}

.tma-dash__contacts-folder-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  min-width: 0;
  flex: 1;
}

.tma-dash__contacts-folder-name {
  font-size: var(--text-size-14);
  line-height: 20px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__contacts-folder-meta {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-folder-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 28px;
  height: 28px;
  padding: 0 var(--space-8);
  border-radius: var(--radius-8);
  background: var(--color-overlay-4);
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.tma-dash__contacts-assigned-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-12);
}

.tma-dash__contacts-assigned-count,
.tma-dash__contacts-assigned-empty {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-assigned-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}

.tma-dash__contacts-assigned {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  width: 100%;
  padding: var(--space-12);
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-12);
  background: rgba(255, 255, 255, 0.5);
  text-align: left;
  cursor: pointer;
  font: inherit;
}

.tma-dash__contacts-assigned:hover {
  background: var(--color-hover);
  border-color: var(--color-border-medium);
}

.tma-dash__contacts-assigned-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-12);
  background: var(--color-overlay-4);
  flex-shrink: 0;
}

.tma-dash__contacts-assigned-icon img {
  width: 20px;
  height: 20px;
  opacity: 0.7;
}

.tma-dash__contacts-assigned-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  min-width: 0;
  flex: 1;
}

.tma-dash__contacts-assigned-title {
  font-size: var(--text-size-14);
  line-height: 20px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__contacts-assigned-meta {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-assigned .tma-status-badge {
  flex-shrink: 0;
}

.tma-dash__contacts-form {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
  padding-right: var(--space-4);
  scrollbar-width: thin;
}

.tma-dash__contacts-form-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
}

.tma-dash__contacts-form-section-title {
  margin: 0;
  font-size: var(--text-size-14);
  font-weight: 600;
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-12) var(--space-16);
}

.tma-dash__contacts-form-field {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  min-width: 0;
}

.tma-dash__contacts-form-field--full {
  grid-column: 1 / -1;
}

.tma-dash__contacts-form-label {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-form-rows {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.tma-dash__contacts-form-row {
  display: grid;
  grid-template-columns: 120px 1fr 32px;
  gap: var(--space-8);
  align-items: center;
}

.tma-dash__contacts-field-select {
  min-width: 0;
  padding: var(--space-8) var(--space-12);
  border: 0.5px solid var(--color-border-medium);
  border-radius: var(--radius-12);
  background: var(--color-bg-input);
  font: inherit;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-field-textarea {
  width: 100%;
  min-height: 96px;
  padding: var(--space-8) var(--space-12);
  border: 0.5px solid var(--color-border-medium);
  border-radius: var(--radius-12);
  background: var(--color-bg-input);
  font: inherit;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
  resize: vertical;
  box-sizing: border-box;
}

.tma-dash__contacts-field-textarea:focus,
.tma-dash__contacts-field-select:focus {
  outline: none;
  border-color: var(--color-text-secondary);
}

.tma-dash__contacts-form-addresses {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.tma-dash__contacts-address-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
  padding: var(--space-12);
  border: 1px solid var(--color-overlay-4);
  border-radius: var(--radius-12);
  background: rgba(255, 255, 255, 0.5);
}

.tma-dash__contacts-address-block-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}

.tma-dash__contacts-address-block-head .tma-dash__contacts-field-select {
  flex: 1;
  max-width: 160px;
}

.tma-dash__contacts-row-remove {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  padding: 0;
  border: none;
  border-radius: var(--radius-8);
  background: transparent;
  cursor: pointer;
}

.tma-dash__contacts-row-remove:hover:not(:disabled) {
  background: var(--color-hover);
}

.tma-dash__contacts-row-remove:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.tma-dash__contacts-row-remove img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__contacts-add-group {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
  align-self: flex-start;
  padding: var(--space-4) var(--space-8);
  border: none;
  border-radius: var(--radius-8);
  background: transparent;
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  cursor: pointer;
}

.tma-dash__contacts-add-group:hover {
  background: var(--color-hover);
  color: var(--color-text-primary);
}

.tma-dash__contacts-add-group img {
  width: 14px;
  height: 14px;
  opacity: 0.6;
}

.tma-dash__contacts-form-row--dates {
  grid-template-columns: 120px 1fr 1fr 32px;
}

.tma-dash__contacts-date-label--hidden {
  visibility: hidden;
  pointer-events: none;
}

.tma-dash__contacts-photo {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.tma-dash__contacts-photo-wrap {
  position: relative;
  width: fit-content;
}

.tma-dash__contacts-photo-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 80px;
  padding: 0;
  border: 1px dashed var(--color-border-medium);
  border-radius: 50%;
  background: var(--color-bg-input);
  cursor: pointer;
  overflow: hidden;
}

.tma-dash__contacts-photo-btn:hover {
  border-color: var(--color-text-secondary);
  background: var(--color-hover);
}

.tma-dash__contacts-photo-placeholder {
  width: 32px;
  height: 32px;
  opacity: 0.45;
}

.tma-dash__contacts-photo-preview {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: none;
}

.tma-dash__contacts-photo-btn[data-has-image] .tma-dash__contacts-photo-placeholder {
  display: none;
}

.tma-dash__contacts-photo-btn[data-has-image] .tma-dash__contacts-photo-preview {
  display: block;
}

.tma-dash__contacts-photo-remove {
  position: absolute;
  top: -4px;
  right: -4px;
  display: none;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: var(--color-bg-card);
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  cursor: pointer;
}

.tma-dash__contacts-photo-btn[data-has-image] + .tma-dash__contacts-photo-remove {
  display: inline-flex;
}

.tma-dash__contacts-photo-remove-icon {
  width: 20px;
  height: 20px;
}

.tma-dash__contacts-photo-input {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

.tma-dash__contacts-photo-hint {
  margin: 0;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-list--profile {
  min-width: 0;
}

.tma-dash__contacts-profile-body {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-20);
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  width: 100%;
  align-content: start;
}

.tma-dash__contacts-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  width: 100%;
}

.tma-dash__contacts-list-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-12);
  padding: var(--space-8) var(--space-12);
  border-radius: var(--radius-8);
}

.tma-dash__contacts-list-item:has(.tma-dash__contacts-list-link:hover) {
  background: var(--color-hover);
}

.tma-dash__contacts-list-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 16px;
  padding-top: 2px;
}

.tma-dash__contacts-list-icon img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__contacts-list-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  min-width: 0;
  flex: 1;
}

.tma-dash__contacts-list-label {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-list-value {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-list-link {
  text-decoration: none;
  color: var(--color-text-primary);
  width: fit-content;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tma-dash__contacts-list-link:hover {
  text-decoration: underline;
}

.tma-dash__contacts-list--edit .tma-dash__contacts-list-item {
  align-items: center;
}

.tma-dash__contacts-profile-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-8) var(--space-16);
}

.tma-dash__contacts-meta-item {
  display: inline-flex;
  align-items: center;
  gap: var(--space-8);
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  min-width: 0;
  white-space: nowrap;
}

.tma-dash__contacts-meta-item span:last-child {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tma-dash__contacts-meta-item img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
  flex-shrink: 0;
}

.tma-dash__contacts-meta-link {
  text-decoration: none;
  color: inherit;
  border-radius: var(--radius-8);
  transition: background 0.15s ease, color 0.15s ease;
}

.tma-dash__contacts-meta-link:hover {
  background: var(--color-hover);
  color: var(--color-text-primary);
}

.tma-dash__contacts-meta-link:hover span:last-child {
  text-decoration: underline;
}

.tma-dash__contacts-field {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  min-width: 0;
}

.tma-dash__contacts-field-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tma-dash__contacts-field-label img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__contacts-field-input {
  flex: 1;
  min-width: 0;
  padding: var(--space-8) var(--space-12);
  border: 0.5px solid var(--color-border-medium);
  border-radius: var(--radius-12);
  background: var(--color-bg-input);
  font: inherit;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-field-input:focus {
  outline: none;
  border-color: var(--color-text-secondary);
}

.tma-dash__contacts-edit-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
  min-height: 24px;
  padding: var(--space-4) var(--space-12);
  border: none;
  border-radius: var(--radius-12);
  background: var(--color-overlay-4);
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-primary);
  cursor: pointer;
}

.tma-dash__contacts-edit-btn:hover {
  background: var(--color-hover);
}

.tma-dash__contacts-edit-btn img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__contacts-profile-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-16);
  width: 100%;
  margin-top: auto;
  padding-top: var(--space-24);
  border-top: 1px solid var(--color-overlay-4);
}

.tma-dash__contacts-stat {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.tma-dash__contacts-stat-label {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-stat-value {
  font-size: 18px;
  font-weight: 600;
  line-height: 28px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-stat-sep {
  width: 1px;
  height: 48px;
  background: var(--color-overlay-4);
  flex-shrink: 0;
}

.tma-dash__contacts-profile-actions {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  flex-shrink: 0;
}

.tma-dash__contacts-icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 24px;
  min-height: 24px;
  padding: var(--space-4);
  border: none;
  border-radius: var(--radius-12);
  background: transparent;
  cursor: pointer;
}

.tma-dash__contacts-icon-btn:hover {
  background: var(--color-hover);
}

.tma-dash__contacts-icon-btn img {
  width: 16px;
  height: 16px;
  opacity: 0.6;
}

.tma-dash__contacts-message-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-4);
  min-height: 24px;
  padding: var(--space-4) var(--space-12);
  border: none;
  border-radius: var(--radius-12);
  background: var(--color-black);
  color: var(--color-text-white);
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  cursor: pointer;
}

.tma-dash__contacts-message-btn img {
  width: 16px;
  height: 16px;
  filter: brightness(0) invert(1);
}

.tma-dash__contacts-schedule {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
  overflow: hidden;
}

.tma-dash__contacts-schedule-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-16);
  flex-shrink: 0;
}

.tma-dash__contacts-schedule-title {
  font-size: var(--text-size-14);
  font-weight: 600;
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-schedule-nav {
  display: flex;
  align-items: center;
  gap: var(--space-8);
}

.tma-dash__contacts-schedule-date {
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-today-btn {
  min-height: 24px;
  padding: var(--space-4) var(--space-12);
  border: none;
  border-radius: var(--radius-12);
  background: var(--color-overlay-4);
  font: inherit;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-primary);
  cursor: pointer;
}

.tma-dash__contacts-schedule-body {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: var(--space-16);
  overflow: hidden;
}

.tma-dash__contacts-schedule-times {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  gap: var(--space-28);
  padding-top: 40px;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  text-align: right;
}

.tma-dash__contacts-schedule-grid-wrap {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tma-dash__contacts-schedule-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: var(--space-4);
  margin-bottom: var(--space-8);
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
  text-align: center;
}

.tma-dash__contacts-schedule-day--today {
  color: var(--color-text-primary);
  font-weight: 600;
}

.tma-dash__contacts-schedule-canvas {
  position: relative;
  flex: 1;
  min-height: 420px;
  border-top: 1px solid var(--color-overlay-4);
}

.tma-dash__contacts-schedule-lines {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.tma-dash__contacts-schedule-vline {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 1px;
  background: var(--color-overlay-4);
  transform: translateX(-50%);
}

.tma-dash__contacts-schedule-today-tag {
  position: absolute;
  top: 0;
  left: calc(3 / 7 * 100% + 100% / 14);
  transform: translate(-50%, -50%);
  padding: 2px var(--space-4);
  border-radius: var(--radius-8);
  background: var(--color-indigo);
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-white);
  z-index: 2;
}

.tma-dash__contacts-schedule-now {
  position: absolute;
  left: 0;
  right: 0;
  z-index: 3;
  pointer-events: none;
}

.tma-dash__contacts-schedule-now-label {
  position: absolute;
  left: 0;
  transform: translateY(-50%);
  padding: 2px var(--space-8) 2px var(--space-4);
  border-radius: var(--radius-8) 0 0 var(--radius-8);
  background: var(--color-black);
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-white);
}

.tma-dash__contacts-schedule-now-line {
  position: absolute;
  left: 52px;
  right: 0;
  top: 50%;
  height: 1px;
  background: var(--color-black);
}

.tma-dash__contacts-event {
  position: absolute;
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  padding: var(--space-8);
  border-radius: var(--radius-8);
  overflow: hidden;
  z-index: 1;
}

.tma-dash__contacts-event--blue {
  background: var(--color-1);
}

.tma-dash__contacts-event--purple {
  background: var(--color-2);
}

.tma-dash__contacts-event-title {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-primary);
}

.tma-dash__contacts-event-time {
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-secondary);
}

.tma-dash__contacts-event-avatars {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.tma-dash__contacts-event-avatar {
  width: 24px;
  height: 24px;
  margin-left: -8px;
  border: 1px solid var(--color-2);
  border-radius: 50%;
  overflow: hidden;
  background: var(--color-overlay-4);
}

.tma-dash__contacts-event-avatar:first-child {
  margin-left: 0;
}

.tma-dash__contacts-event-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.tma-dash__contacts-event-avatar--more {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--color-blue);
  border-color: var(--color-2);
  font-size: var(--text-size-12);
  line-height: 16px;
  color: var(--color-text-white);
}

/* ── Calendar page ─────────────────────────────────── */

.tma-dash__calendar-mount {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.tma-dash__calendar {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.tma-dash__contacts-schedule--standalone {
  flex: 1;
  min-height: 0;
}

.tma-dash__contacts-schedule--standalone .tma-dash__contacts-schedule-canvas {
  min-height: 520px;
}

/* ── Pricing page (32546:96132) ─────────────────────── */

.tma-dash__pricing-page {
  display: flex;
  flex-direction: column;
  gap: var(--space-28);
  min-width: 0;
}

.tma-dash__pricing-hero {
  position: relative;
  min-height: 290px;
  border-radius: var(--radius-20);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-24);
}

.tma-dash__pricing-hero-bg {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.4) 100%),
    rgba(0, 0, 0, 0.2);
  background-color: #000;
}

.tma-dash__pricing-hero-decor {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.tma-dash__pricing-decor {
  position: absolute;
  opacity: 0.85;
}

.tma-dash__pricing-decor--1 {
  width: 78px;
  height: 78px;
  top: 18%;
  right: 12%;
}

.tma-dash__pricing-decor--2 {
  width: 52px;
  height: 52px;
  bottom: 22%;
  right: 28%;
}

.tma-dash__pricing-decor--3 {
  width: 40px;
  height: 40px;
  bottom: 18%;
  left: 18%;
}

.tma-dash__pricing-decor--4 {
  width: 32px;
  height: 32px;
  top: 22%;
  left: 10%;
}

.tma-dash__pricing-decor--5 {
  width: 100px;
  height: 100px;
  top: 8%;
  right: 32%;
}

.tma-dash__pricing-hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-28);
  max-width: 100%;
}

.tma-dash__pricing-hero-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-8);
  text-align: center;
}

.tma-dash__pricing-hero-title {
  margin: 0;
  font-size: 48px;
  line-height: 56px;
  font-weight: 600;
  color: #fff;
}

.tma-dash__pricing-hero-subtitle {
  margin: 0;
  font-size: var(--text-size-12);
  line-height: 16px;
  color: rgba(255, 255, 255, 0.4);
  max-width: 360px;
}

.tma-dash__pricing-billing {
  width: 260px;
  padding: var(--space-4);
  border-radius: var(--radius-16);
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(40px);
}

.tma-dash__pricing-billing .tma-tab {
  flex: 1;
  min-height: 24px;
  padding: var(--space-4) var(--space-12);
}

.tma-dash__pricing-cards {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-28);
}

.tma-dash__pricing-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
  padding: var(--space-40);
  border-radius: var(--radius-20);
  background: var(--dash-panel-bg, #f9f9fa);
  min-width: 0;
}

.tma-dash__pricing-card-name {
  margin: 0;
  font-size: 18px;
  line-height: 28px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__pricing-card-price {
  display: flex;
  align-items: flex-end;
  gap: var(--space-8);
}

.tma-dash__pricing-card-amount {
  font-size: 48px;
  line-height: 56px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.tma-dash__pricing-card-unit {
  padding-bottom: 10px;
  font-size: var(--text-size-14);
  line-height: 20px;
  color: var(--color-text-secondary);
}

.tma-dash__pricing-card-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 48px;
  padding: var(--space-12) var(--space-20);
  border: none;
  border-radius: var(--radius-20);
  background: var(--color-text-primary);
  color: #fff;
  font: inherit;
  font-size: var(--text-size-16);
  line-height: 24px;
  cursor: pointer;
}

.tma-dash__pricing-card-btn:hover:not(:disabled) {
  opacity: 0.9;
}

.tma-dash__pricing-card-btn--current,
.tma-dash__pricing-card-btn:disabled {
  opacity: 0.2;
  cursor: default;
}

.tma-dash__pricing-features {
  list-style: none;
  margin: 0;
  padding: 0 0 var(--space-16);
  display: flex;
  flex-direction: column;
  gap: var(--space-20);
}

.tma-dash__pricing-feature {
  display: flex;
  align-items: center;
  gap: var(--space-8);
}

.tma-dash__pricing-feature-icon {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  opacity: 0.8;
}

.tma-dash__pricing-feature-label {
  font-size: 18px;
  line-height: 28px;
  color: var(--color-text-primary);
}

@media (max-width: 1100px) {
  .tma-dash__pricing-cards {
    grid-template-columns: 1fr;
  }

  .tma-dash__pricing-hero-title {
    font-size: 36px;
    line-height: 44px;
  }
}

@media (max-width: 1100px) {
  .tma-dash__contacts-page {
    flex-direction: column;
    overflow: auto;
  }

  .tma-dash__contacts-layout {
    flex-direction: column;
    overflow: auto;
  }

  .tma-dash__contacts-directory {
    flex: 0 0 auto;
    max-height: 240px;
  }

  .tma-dash__contacts-directory.tma-dash__contacts-directory--standalone {
    flex: 0 0 auto;
    width: 100%;
    max-width: 100%;
    max-height: 280px;
  }

  .tma-dash__contacts-detail {
    flex: 0 0 auto;
  }

  .tma-dash__contacts-profile-stats {
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  .tma-dash__contacts-profile-body {
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  .tma-dash__contacts-form-grid {
    grid-template-columns: 1fr;
  }

  .tma-dash__contacts-form-row {
    grid-template-columns: 1fr;
  }

  .tma-dash__contacts-form-row--dates {
    grid-template-columns: 1fr;
  }

  .tma-dash__contacts-schedule-canvas {
    min-height: 360px;
  }

  .tma-dash__contacts-schedule--standalone .tma-dash__contacts-schedule-canvas {
    min-height: 400px;
  }
}

/* ── Email templates ───────────────────────────────── */

.tma-dash__email-list--templates .tma-dash__email-list-head--templates {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
  padding: var(--space-12) var(--space-16);
}

.tma-dash__email-template-list-title {
  font-size: var(--font-size-14);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.tma-dash__email-template-list-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 20px;
  height: 20px;
  padding: 0 var(--space-6);
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  font-size: var(--font-size-12);
