  text-decoration: none;
}

.tma-dash__account-settings-callout-btn {
  flex: 0 0 auto;
  min-height: 24px;
  padding: var(--space-4) var(--space-12);
  border: 0;
  border-radius: var(--radius-12);
  background: var(--color-hover);
  font: inherit;
  font-size: 12px;
  line-height: 16px;
  color: var(--color-text-primary);
  cursor: pointer;
}

.tma-dash__account-settings-connect-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-16);
  width: 100%;
  padding-bottom: var(--space-16);
}

.tma-dash__account-settings-connect-row--border {
  border-bottom: 1px solid var(--color-overlay-10);
}

.tma-dash__account-settings-connect-main {
  display: flex;
  flex: 1 1 280px;
