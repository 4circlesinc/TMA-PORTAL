APP_NAME="TM ANTOINE Advisory"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Disk for uploaded profile photos. Use s3 in production (Laravel Cloud's local
# filesystem is ephemeral); leave as public/local for development.
AVATAR_DISK=public
# Mail is queued, so this needs a worker running: php artisan queue:work
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
# Laravel Cloud managed cache is TLS-only; leave as tcp for a local Redis.
REDIS_SCHEME=tcp
REDIS_USERNAME=
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail. Development writes to storage/logs/laravel.log. Production sends via
# either Microsoft 365 SMTP (MAIL_MAILER=smtp) or Resend (MAIL_MAILER=resend).
#
# Microsoft 365: MAIL_USERNAME is a licensed mailbox with SMTP AUTH enabled,
# MAIL_PASSWORD is that mailbox's password (or an app password if MFA is on).
# MAIL_FROM_ADDRESS must be that mailbox or one it holds SendAs rights to.
# Throttled to 30 messages/minute and 10,000 recipients/day.
#
# Resend: MAIL_FROM_ADDRESS must be on a domain verified in Resend, or every
# send is rejected.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_SCHEME=smtp
MAIL_USERNAME=
MAIL_PASSWORD=

RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"


# Reverb (websockets) — powers live updates on the Messages page.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
